<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" prefHeight="600" prefWidth="800" spacing="10"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ac.csg.in2033.ipos.pu.gui.dashboard.A_DashboardSceneController">

    <padding>
        <Insets top="10" bottom="10" left="10" right="10"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Admin Dashboard" style="-fx-font-size: 18; -fx-font-weight: bold;" />
    </HBox>

    <!-- TOOLBAR -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Create Promotion" onAction="#onCreateClick" />
    </HBox>

    <!-- PROMOTIONS TABLE -->
    <TableView fx:id="promotionsTable" prefHeight="400" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" />
            <TableColumn fx:id="startColumn" text="Start Date" prefWidth="150" />
            <TableColumn fx:id="endColumn" text="End Date" prefWidth="150" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="80" />
            <!-- TODO: MAKE PRODUCTS COLLAPSIBLE? -->
            <TableColumn fx:id="productsColumn" text="Products" prefWidth="80" />
        </columns>
    </TableView>

    <!-- ACTION BUTTONS -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Edit" onAction="#onEditClick" />
        <Button text="Terminate" onAction="#onTerminateClick" />
        <Button text="Delete" onAction="#onDeleteClick" />
    </HBox>

</VBox>