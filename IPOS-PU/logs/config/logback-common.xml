<configuration>
    <variable scope="local" name="defaultPattern" value="%date{HH:mm:ss.SSS} [Thread.%t] %-30c{1} %-5p %msg%n"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${defaultPattern}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>